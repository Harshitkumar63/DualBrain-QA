 # ============================================================
# Hybrid RAG + LoRA System — Environment Configuration
# ============================================================

# Host and Port Configuration
PORT=8000
HOST=0.0.0.0

# Directory paths
DATA_DIR=./data
PEFT_MODEL_PATH=./models/adapters
BASE_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.1

# Optional CPU Fallback overrides
# If CUDA is unavailable, the pipeline falls back to this smaller model
CPU_FALLBACK_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0

# Rate Limiter Settings
# Maximum burst capacity of requests
RATE_LIMIT_CAPACITY=10.0
# Replenish rate (tokens per second)
RATE_LIMIT_RATE=1.0

# Backend endpoint configured for the Streamlit UI
BACKEND_URL=http://localhost:8000
